# Broker selection — "alpaca" (paper default) or "webull" (live cutover 2026-06-12)
BROKER=alpaca

# Alpaca Paper Trading API (NEVER use live credentials here)
ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Webull OpenAPI credentials (developer.webull.com — official OpenAPI).
# Required only when BROKER=webull.
WEBULL_API_KEY=your_webull_key_here
WEBULL_API_SECRET=your_webull_secret_here
WEBULL_ACCOUNT_ID=your_webull_account_id
WEBULL_BASE_URL=https://api.webull.com

# Shadow mode (WS3 step 6) — when BROKER=webull and ENABLE_SUBMIT is unset
# or "false", WebullAdapter.submit_order returns shadow_mode without
# placing real orders. Flip to "true" at cutover.
ENABLE_SUBMIT=false

# Gmail App Password for daily reports
GMAIL_USER=bharath8887@gmail.com
GMAIL_APP_PASSWORD=generate_at_myaccount.google.com_security_app_passwords

# Bot mode — "paper" or "live". "live" requires WS4 live_capital.lock signed.
BOT_MODE=paper
