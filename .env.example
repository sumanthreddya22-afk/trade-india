# ── Broker ──────────────────────────────────────────────────────────────────
# Zerodha Kite Connect API (https://kite.trade)
# Step 1: Create an app at https://developers.zerodha.com
# Step 2: Use OAuth login flow to get request_token → exchange for access_token
# Step 3: Access tokens expire at 06:00 IST daily — refresh before market open
BROKER=zerodha

ZERODHA_API_KEY=your_kite_api_key_here
ZERODHA_API_SECRET=your_kite_api_secret_here
ZERODHA_ACCESS_TOKEN=your_daily_access_token_here

# Redirect URL registered in Kite Connect developer console
ZERODHA_REDIRECT_URL=http://localhost:8080/kite/callback

# ── Bot mode ─────────────────────────────────────────────────────────────────
# "paper" = Zerodha paper trading / sandbox mode
# "live"  = requires live_capital.lock signed by operator
BOT_MODE=paper

# ── Market ───────────────────────────────────────────────────────────────────
# Exchange: NSE (equities/ETFs), BSE (equities), NFO (F&O)
EXCHANGE=NSE

# Timezone — IST (fixed UTC+5:30, no DST)
# Override only if operator is in a different timezone
TRADING_BOT_TZ=Asia/Kolkata

# NSE trading hours: 09:15–15:30 IST, Mon–Fri
# Pre-open: 09:00–09:15 IST (call auction)

# ── Optional Intel Feed API Keys ─────────────────────────────────────────────
# RBI DBIE — free, no key needed for basic series
# FBIL reference rates — free, no key needed
# NSE data API — free (rate limits apply on direct calls)

# Optional: CoinDCX for crypto INR pairs (if crypto lane enabled)
COINDCX_API_KEY=your_coindcx_key_here
COINDCX_API_SECRET=your_coindcx_secret_here

# ── Notifications ────────────────────────────────────────────────────────────
# Gmail App Password for daily reports
GMAIL_USER=sumanth.avula95@gmail.com
GMAIL_APP_PASSWORD=generate_at_myaccount.google.com_security_app_passwords

# ── Feature flags ────────────────────────────────────────────────────────────
# LLM in trading hot path — DEFAULT OFF; Phase 0 hard rule
TRADING_BOT_ENABLE_LLM_HOTPATH=false

# Live param mutation — DEFAULT OFF
TRADING_BOT_ALLOW_LIVE_PARAM_WRITES=0

# ── Submit toggle ────────────────────────────────────────────────────────────
# When false, ZerodhaAdapter.submit_order returns shadow_mode without
# placing real orders. Flip to "true" only after paper validation.
ENABLE_SUBMIT=false
