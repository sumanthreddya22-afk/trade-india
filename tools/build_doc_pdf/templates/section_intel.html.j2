{% from "macros.html.j2" import table, callout, pill %}
<section class="page-wide">
  <div class="chapter-strip"><span class="label">Chapter 7</span><span class="name">News &amp; intelligence sources</span></div>
  <h1>Every feed the bot consumes</h1>

  <p>{{ intel_sources.intro }}</p>

  <div style="margin: .4rem 0 .6rem;">
    {% for f in intel_sources.fail_modes_legend %}
      {{ pill(f.label, f.class) }}<span style="font-size:9pt;color:var(--c-muted);"> — {{ f.desc }}</span><br/>
    {% endfor %}
  </div>

  {% set _rows = [] %}
  {% for r in intel_sources.table.rows %}
    {% set fail = r[5] %}
    {% set fail_pill %}<span class="pill {{ 'bad' if fail == 'fail-closed' else 'info' }} mono">{{ fail }}</span>{% endset %}
    {% set _ = _rows.append([r[0], "<code>" ~ r[1] ~ "</code>", "<code>" ~ r[2] ~ "</code>", r[3], r[4], fail_pill]) %}
  {% endfor %}
  {{ table(intel_sources.table.headers, _rows, intel_sources.table.widths, compact=true,
           caption="Per-source endpoint, refresh cadence, consuming workflow, and fail mode.") }}

  {% for c in intel_sources.callouts %}
    {{ callout(c.class, c.lead, c.body) }}
  {% endfor %}
</section>
