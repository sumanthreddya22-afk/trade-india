<section class="cover">
  <div class="top">
    <div class="eyebrow">{{ meta.author }}</div>
    <h1 class="title">{{ meta.title }}</h1>
    <div class="accent"></div>
    <div class="subtitle">{{ meta.subtitle }}</div>
    <p style="margin-top:1rem; color:var(--c-body); font-size:11pt; line-height:1.5;">
      {{ meta.tagline }}
    </p>
  </div>
  <div>
    <dl class="meta">
      <dt>Version</dt>      <dd>{{ meta.version }}</dd>
      <dt>Generated</dt>    <dd>{{ meta.date_iso }}</dd>
      <dt>Repository</dt>   <dd><code>{{ meta.repo }}</code></dd>
      <dt>Trading venue</dt><dd><code>{{ meta.venue }}</code></dd>
      <dt>LLM model</dt>    <dd><code>{{ meta.model_pin }}</code> — pinned across all roles</dd>
      <dt>Workflows</dt>    <dd>3 live + 1 library-only (W1 stocks · W2 crypto · W3 wheel · W4 news-trader)</dd>
    </dl>
    <div class="footer-stamp">
      <span>Document generated by <code>tools/build_doc_pdf</code> — HTML + Mermaid + Chromium pipeline.</span>
      <span>1</span>
    </div>
  </div>
</section>
<div class="page-break"></div>
